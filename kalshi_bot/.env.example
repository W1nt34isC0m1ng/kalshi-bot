KALSHI_ENV=demo
KALSHI_API_KEY_ID=your_key_id_here
KALSHI_PRIVATE_KEY_PATH=/absolute/path/to/kalshi-private-key.pem
KALSHI_BASE_URL=https://demo-api.kalshi.co/trade-api/v2
KALSHI_WS_URL=wss://demo-api.kalshi.co/trade-api/ws/v2
CATEGORY_FILTER=Economics,Financials,Crypto,Weather
MIN_DAILY_VOLUME=200
MAX_POSITION_PER_MARKET=5
MAX_NOTIONAL_CENTS_PER_MARKET=2500
MAX_TOTAL_NOTIONAL_CENTS=10000
EDGE_THRESHOLD_CENTS=4
ORDER_TTL_SECONDS=25
POLL_INTERVAL_SECONDS=8
DRY_RUN=true
