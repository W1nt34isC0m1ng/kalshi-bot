# Copy this file to .env and fill in your credentials.
# Never commit the .env file to version control.

# Kalshi account credentials (required)
KALSHI_EMAIL=your_email@example.com
KALSHI_PASSWORD=your_password_here

# Number of contracts to buy per 15-minute cycle (default: 1)
NUM_CONTRACTS=1

# Kalshi series ticker for the BTC 15-min up/down market (default: KXBTCD)
BTC_SERIES=KXBTCD
